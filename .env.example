# Copy this file to ".env" and fill in your values.
# NEVER commit the real .env — it is git-ignored.

# Private key of the wallet used to deploy and to sign transactions server-side
# (with or without the 0x prefix). Use a testnet key, not a mainnet key.
GENLAYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Target network: studionet | testnet-bradbury | testnet-asimov | localnet
GENLAYER_NETWORK=testnet-bradbury

# Deployed contract address (set automatically after the first deploy; the
# backend reads it from here).
CONTRACT_ADDRESS=

# Separate signer used ONLY for appeals. Must be a DIFFERENT account than the
# deployer/owner — GenLayer reverts (CanNotAppeal) if you appeal your own tx.
# Fund it with a little GEN for gas. Leave blank to disable appeal submission.
GENLAYER_APPELLANT_KEY=

# Optional: backend HTTP port (defaults to 8787).
# PORT=8787
